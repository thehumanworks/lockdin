{
  "manifest_version": 3,
  "name": "LockdIn",
  "version": "1.3.7",
  "description": "Hides LinkedIn's main feed, news rail, and notifications entry behind a motivational panel with rotating artwork backdrops.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle LockdIn"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "all_frames": true,
      "css": [
        "feed-block.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/fonts/*",
        "assets/images/*",
        "assets/icons/*"
      ],
      "matches": [
        "https://www.linkedin.com/*"
      ]
    }
  ]
}
